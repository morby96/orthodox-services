      "subsections": [
        {
          "id": "opening-blessing",
          "title": "Opening Blessing",
          "items": [
            {
              "id": "opening-blessing-1",
              "role": "deacon",
              "type": "line",
              "en": "Bless, Master.",
              "cu": "",
              "sr": ""
            },
            {
              "id": "opening-blessing-2",
              "role": "priest",
              "type": "line",
              "en": "Blessed is the Kingdom of the Father, and of the Son, and of the Holy Spirit, now and ever, and unto ages of ages.",
              "cu": "",
              "sr": ""
            },
            {
              "id": "opening-blessing-3",
              "role": "choir",
              "type": "line",
              "en": "Amen.",
              "cu": "",
              "sr": ""
            },
            {
              "id": "opening-blessing-4",
              "role": "note",
              "type": "line",
              "en": "If it is between Pascha and the Ascension, before the Great Litany, the clergy chant the hymn “Christ is Risen” two and a half times, and the choir finishes.",
              "cu": "",
              "sr": ""
            }
          ]
        }
      ]
    }
  ]
